{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{data/**,.cache,.env,.vscode/**,app/.venv/**,**/__pycache__/**,*.log}"
    }
  }
}
